{
  "manifest_version": 3,
  "name": "Grima's Bane",
  "version": "0.1.0",
  "description": "Silences the whisper that feeds you Shorts. Blocks Shorts/Reels on YouTube, Facebook, Instagram, and TikTok — unless you toggle it off.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "action": {
    "default_title": "Grima's Bane",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.facebook.com/*",
        "*://*.instagram.com/*",
        "*://*.tiktok.com/*"
      ],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
